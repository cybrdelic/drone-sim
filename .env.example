# Optional local overrides for the browser debug bridge.
# `set_state` is disabled unless a token is configured here and matched by the bridge client.

VITE_DRONE_SIM_DEBUG_ENABLED="true"
VITE_DRONE_SIM_DEBUG_URL="ws://127.0.0.1:8787"
VITE_DRONE_SIM_DEBUG_TOKEN="replace-me-with-a-local-shared-secret"
